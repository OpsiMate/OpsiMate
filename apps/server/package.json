{
	"name": "@OpsiMate/server",
	"version": "1.0.0",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"start": "node dist/index.js",
		"start:worker": "node dist/worker.js",
		"debug": "node --inspect=0.0.0.0:9229 dist/index.js",
		"debug:worker": "node --inspect=0.0.0.0:9230 dist/worker.js",
		"build": "vite build --config vite.config.prod.ts",
		"build-dev": "vite build --mode development",
		"dev": "vite",
		"dev:worker": "tsx watch src/worker.ts",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint src --ext .ts",
		"lint-fix": "eslint src --ext .ts --fix",
		"format": "prettier --check .",
		"format-fix": "prettier --write .",
		"check": "pnpm run format && pnpm run lint",
		"fix": "pnpm run format-fix && pnpm run lint-fix"
	},
	"dependencies": {
		"@OpsiMate/custom-actions": "workspace:*",
		"@OpsiMate/shared": "workspace:*",
		"@kubernetes/client-node": "^1.4.0",
		"@types/cors": "^2.8.19",
		"@types/jsonwebtoken": "^9.0.10",
		"axios": "^1.18.1",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^12.11.1",
		"cors": "^2.8.6",
		"express": "^4.22.2",
		"express-promise-router": "^4.1.1",
		"js-yaml": "^4.3.0",
		"jsonwebtoken": "^9.0.3",
		"multer": "^2.2.0",
		"node-ssh": "^13.2.1",
		"nodemailer": "^7.0.13",
		"sshpk": "^1.18.0",
		"uuid": "^13.0.2",
		"vite": "^7.3.6",
		"vite-plugin-node": "^7.0.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/express": "^4.17.25",
		"@types/express-promise-router": "^2.0.1",
		"@types/js-yaml": "^4.0.9",
		"@types/multer": "^2.2.0",
		"@types/node": "^22.20.1",
		"@types/nodemailer": "^7.0.12",
		"@types/supertest": "^6.0.3",
		"@vitest/coverage-v8": "^3.2.7",
		"eslint": "^9.39.5",
		"supertest": "^7.2.2",
		"ts-node": "^10.9.2",
		"tsx": "^4.23.1",
		"typescript": "^5.9.3",
		"vitest": "^3.2.7"
	}
}
